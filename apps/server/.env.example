# ── Server ──────────────────────────────────────────────────────────────
PORT=3001
# Origin of the web client (used for CORS + cookie). Vite dev default below.
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────
# Local mongod, or a MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/martelli-buyers-local

# ── Session ─────────────────────────────────────────────────────────────
# Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# ── OTP ─────────────────────────────────────────────────────────────────
OTP_TTL_MIN=10

# ── Super admin (RBAC) ───────────────────────────────────────────────────
# Email of the single super-admin account. This user always has every
# permission, can never be locked out, and is the only account allowed to
# create/edit/delete roles. On boot a user with this email is provisioned at
# the 'admin' role so they can sign in via OTP.
# REQUIRED: with self-signup disabled, this is the only way the first account
# exists — the super admin then invites everyone else from the Team page.
SUPER_ADMIN_EMAIL=
# How many days an invite link stays valid before it must be re-sent.
INVITE_TTL_DAYS=7

# ── SendGrid (Web API over HTTPS) ────────────────────────────────────────
# Uses SendGrid's HTTPS API (not SMTP) so email works on hosts that block
# outbound SMTP ports, e.g. Render's free tier.
# - SENDGRID_API_KEY: a key with "Mail Send" permission.
# - EMAIL_FROM: a sender or domain you've verified in SendGrid.
# If SENDGRID_API_KEY is blank in dev, OTP codes are logged to the console
# instead of emailed.
SENDGRID_API_KEY=
EMAIL_FROM="Martelli Buyers <no-reply@yourdomain.com>"

# ── AI (Gemini via OpenRouter) ───────────────────────────────────────────
# Used for call/meeting summaries. Get a key at https://openrouter.ai/keys
# If blank, the AI summary feature returns a "not configured" error.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# ── AWS S3 (property photo/video uploads) ────────────────────────────────
# IAM key needs s3:PutObject/DeleteObject/GetObject on the bucket.
# Bucket needs a public-read policy on the properties/* prefix and CORS
# allowing PUT/GET from the web origin.
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Optional CDN/custom domain; defaults to https://<bucket>.s3.<region>.amazonaws.com
S3_PUBLIC_BASE_URL=
# Key prefix under which uploads are stored AND publicly readable. Leave blank
# for a dedicated bucket whose policy grants public read on the app's prefixes.
# Set to "public" when sharing a bucket whose policy only exposes "public/*"
# (objects are then stored as public/avatar/..., public/property/..., etc.).
S3_PUBLIC_PREFIX=

# ── Invoice reminders ────────────────────────────────────────────────────
# Automated overdue-invoice chasing (only runs when SendGrid is configured).
# Days between reminders for one invoice, max reminders per invoice, and how
# often the scheduler scans for overdue invoices.
INVOICE_REMINDER_INTERVAL_DAYS=3
INVOICE_REMINDER_MAX=3
INVOICE_REMINDER_SCAN_HOURS=12

# ── Xero (invoice sync) ──────────────────────────────────────────────────
# Real OAuth 2.0 invoice push + webhook status sync. While CLIENT_ID/SECRET are
# blank, "Send to Xero" stays gated ("Not configured"); invoices are still real
# PDFs you can download/email.
# - Register an app at https://developer.xero.com → Client ID/Secret.
# - Add the redirect URI below to the app (and your prod URL).
# - Create an "Invoices" webhook in the app → paste its signing key.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:3001/api/xero/callback
XERO_WEBHOOK_KEY=
# Revenue account code (your Xero chart of accounts) + GST tax type (NZ 15%).
XERO_SALES_ACCOUNT_CODE=200
XERO_TAX_TYPE=OUTPUT2
# Space-separated OAuth scopes — must EXACTLY match the scopes enabled on your
# Xero app (newer apps use granular scopes). Invoice push needs an invoices/
# transactions write scope + a contacts scope, plus offline_access for refresh.
XERO_SCOPES=openid profile email accounting.transactions accounting.contacts offline_access

# ── Outlook / Microsoft Graph (email sync) ───────────────────────────────
# Pulls Inbox + Sent mail from one org-wide Outlook mailbox into the CRM and
# auto-links each email to a matching client/deal. While CLIENT_ID/SECRET are
# blank, the Outlook card stays gated ("Not configured"). Read-only ingest —
# sending stays on SendGrid.
# - Register an app at https://entra.microsoft.com (App registrations) →
#   Client ID + a client secret.
# - Add the redirect URI below to the app's web redirect URIs (and your prod URL).
# - Grant DELEGATED Microsoft Graph permissions: Mail.Read, User.Read, offline_access.
# - During Connect, sign in as the mailbox you want to sync (or set MS_MAILBOX to
#   a shared mailbox the connecting account has delegated access to).
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# 'common' = work + personal accounts; or a tenant id to restrict to one org.
MS_TENANT=common
MS_REDIRECT_URI=http://localhost:3001/api/outlook/callback
# Optional: a true Exchange shared mailbox address (read via /users/{addr}).
# Leave blank to read the signed-in account via /me.
MS_MAILBOX=
# Space-separated Graph scopes — must match the delegated permissions granted.
MS_SCOPES=offline_access openid profile email User.Read Mail.Read
# How often the background delta sync runs (minutes).
OUTLOOK_SYNC_MINUTES=10

# ── RILO Meet (video meetings) ───────────────────────────────────────────
# Server-side proxy to the external RILO Meet API. The key is forwarded as the
# `x-rilo-meet-key` header and is NEVER exposed to the browser. While blank, the
# Meet page in the sidebar shows a "Not configured" notice.
# - hostEmail on created meetings must be an existing RILO user.
# - Soft rate limit: 60 meetings/hour per key.
RILO_MEET_API_KEY=
# Override only if RILO gives you a different host (defaults to production).
RILO_MEET_BASE_URL=https://decoded-studios-api.onrender.com

SUPER_ADMIN_EMAIL=mahin.malek@savannah-labs.com
